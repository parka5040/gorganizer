#!/bin/bash
# Gorganizer runtime launcher. Installed to @@PREFIX@@/bin/gorganizer.
# What the .desktop file's Exec= line points at.
#
# Responsibilities:
#   - --nxm <URI>      Forward the URL to the running daemon (one-shot).
#   - --register-nxm   Re-run MIME handler registration.
#   - (default)        Spawn the daemon, wait for its socket, exec the GUI in
#                      the foreground, and tear the daemon down on exit.
#
# Build/install concerns live in install.sh. Distro/dep detection lives there
# too. This script must stay short and runtime-only.
set -euo pipefail

PREFIX="@@PREFIX@@"
DAEMON_BIN="$PREFIX/bin/gorganizerd"
GUI_BIN="$PREFIX/libexec/gorganizer/gorganizer-gui"

# Runtime paths — must match internal/config/paths.go and
# cmd/gorganizerd/singleton.go. Keep in sync.
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/gorganizer"
SOCKET_PATH="$RUNTIME_DIR/gorganizer.sock"
LOCK_PATH="$RUNTIME_DIR/gorganizerd.lock"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/gorganizer"
DAEMON_LOG="$STATE_DIR/gorganizerd.log"

if [ -t 1 ]; then
    CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'; RED='\033[0;31m'; RESET='\033[0m'
else
    CYAN=''; GREEN=''; YELLOW=''; RED=''; RESET=''
fi
log()  { echo -e "${CYAN}[gorganizer]${RESET} $*"; }
ok()   { echo -e "${CYAN}[gorganizer]${RESET} ${GREEN}OK${RESET} $*"; }
warn() { echo -e "${CYAN}[gorganizer]${RESET} ${YELLOW}!!${RESET} $*"; }
err()  { echo -e "${CYAN}[gorganizer]${RESET} ${RED}XX${RESET} $*" >&2; }

# --- argument handling ----------------------------------------------------

case "${1:-}" in
    --nxm)
        # Short-lived: forward the URL to the running daemon and exit.
        # Intentionally does NOT touch the daemon lifecycle — the user's
        # live daemon is already running and probably has downloads in
        # flight; killing it just to forward one URL would cancel them.
        URI="${2:-}"
        if [ -z "$URI" ]; then
            err "Missing URI after --nxm"
            exit 2
        fi
        if [ ! -x "$DAEMON_BIN" ]; then
            err "Daemon not installed at $DAEMON_BIN"
            exit 1
        fi
        exec "$DAEMON_BIN" --handle-nxm "$URI"
        ;;
    --register-nxm)
        # Re-run the MIME handler registration. Useful if the user's
        # mimeapps.list got clobbered or they suspect browser routing
        # is broken.
        if [ ! -x "$PREFIX/share/gorganizer/register-nxm.sh" ]; then
            err "register-nxm helper missing at $PREFIX/share/gorganizer/register-nxm.sh"
            err "Re-run install.sh to repair the install."
            exit 1
        fi
        exec "$PREFIX/share/gorganizer/register-nxm.sh"
        ;;
    --version)
        if [ -x "$DAEMON_BIN" ]; then
            "$DAEMON_BIN" --version
        else
            echo "gorganizer (daemon not installed)"
        fi
        exit 0
        ;;
    --help|-h)
        cat <<USAGE
Gorganizer — Native Linux mod organizer for Bethesda games

Usage: gorganizer [OPTION]

  (none)            Spawn the daemon and launch the GUI.
  --nxm <URI>       Forward an nxm:// link to the running daemon.
  --register-nxm    Re-run system nxm:// MIME handler registration.
  --version         Print version information.
  --help, -h        Show this message.

For uninstall, run: $PREFIX/share/gorganizer/uninstall.sh
USAGE
        exit 0
        ;;
    "")
        : # default: launch the GUI
        ;;
    *)
        err "Unknown option: $1"
        echo "Run 'gorganizer --help' for usage." >&2
        exit 2
        ;;
esac

if [ ! -x "$DAEMON_BIN" ]; then
    err "Daemon binary missing at $DAEMON_BIN"
    err "Re-run install.sh to repair the install."
    exit 1
fi
if [ ! -x "$GUI_BIN" ]; then
    err "GUI binary missing at $GUI_BIN"
    err "Re-run install.sh to repair the install."
    exit 1
fi

# --- daemon lifecycle ------------------------------------------------------
# The frontend used to auto-spawn the daemon, which left orphans every time:
# internal/ipc/server.go unconditionally os.Remove()s the socket file on
# bind, so the previous daemon kept its listening fd but lost the
# filesystem entry and never exited. Ten restarts = ten orphan daemons.
# This launcher owns daemon lifetime: kill stale, spawn one, trap exit.

kill_stale_daemons() {
    if ! pgrep -x gorganizerd >/dev/null; then
        return 0
    fi
    log "Terminating stale gorganizerd process(es)..."
    pkill -TERM -x gorganizerd 2>/dev/null || true
    local i
    for i in $(seq 1 30); do
        pgrep -x gorganizerd >/dev/null || break
        sleep 0.1
    done
    if pgrep -x gorganizerd >/dev/null; then
        warn "Stubborn daemons, SIGKILL"
        pkill -KILL -x gorganizerd 2>/dev/null || true
        sleep 0.3
    fi
    rm -f "$SOCKET_PATH" "$LOCK_PATH"
}

DAEMON_PID=""
start_daemon() {
    mkdir -p "$RUNTIME_DIR" "$STATE_DIR"
    : > "$DAEMON_LOG"

    "$DAEMON_BIN" --log-level info >"$DAEMON_LOG" 2>&1 &
    DAEMON_PID=$!

    local i
    for i in $(seq 1 50); do
        if [ -S "$SOCKET_PATH" ]; then
            ok "Daemon up (pid $DAEMON_PID, log: $DAEMON_LOG)"
            return 0
        fi
        if ! kill -0 "$DAEMON_PID" 2>/dev/null; then
            err "Daemon exited during startup. Last 20 log lines:"
            tail -20 "$DAEMON_LOG" | sed 's/^/    /' >&2 || true
            exit 1
        fi
        sleep 0.1
    done
    err "Daemon started but socket never appeared at $SOCKET_PATH"
    tail -20 "$DAEMON_LOG" | sed 's/^/    /' >&2 || true
    kill -TERM "$DAEMON_PID" 2>/dev/null || true
    exit 1
}

stop_daemon() {
    local rc=$?
    if [ -n "${DAEMON_PID:-}" ] && kill -0 "$DAEMON_PID" 2>/dev/null; then
        kill -TERM "$DAEMON_PID" 2>/dev/null || true
        local i
        for i in $(seq 1 50); do
            kill -0 "$DAEMON_PID" 2>/dev/null || break
            sleep 0.1
        done
        if kill -0 "$DAEMON_PID" 2>/dev/null; then
            kill -KILL "$DAEMON_PID" 2>/dev/null || true
        fi
    fi
    rm -f "$SOCKET_PATH" "$LOCK_PATH"
    exit "$rc"
}

# Silence Qt6 platform-integration noise on systems without libsystemd or
# a cooperative D-Bus notification server. Doesn't mute Qt's actual errors.
export QT_LOGGING_RULES="${QT_LOGGING_RULES:+$QT_LOGGING_RULES;}qt.dbus.*=false;qt.qpa.systemtray.*=false;qt.qpa.theme.dbus.*=false;qt.qpa.theme.debug=false"

kill_stale_daemons
start_daemon
trap stop_daemon EXIT INT TERM

exec "$GUI_BIN" "$@"
